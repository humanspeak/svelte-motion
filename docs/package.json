{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/fetch-github-stats.ts && tsx ./scripts/generate-social-cards.ts && node ./scripts/generate-registry.mjs && vite build",
        "cf-typegen": "wrangler types src/worker-configuration.d.ts",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "pnpm run build && wrangler pages deploy",
        "dev": "vite dev",
        "format": "prettier --write .",
        "generate-social": "tsx ./scripts/generate-social-cards.ts",
        "lint": "prettier --check . && eslint .",
        "prepare": "svelte-kit sync || echo ''",
        "preview": "pnpm run build && wrangler pages dev",
        "registry:generate": "node ./scripts/generate-registry.mjs",
        "registry:watch": "chokidar 'src/lib/shadcn/ui/**/*.svelte' 'src/lib/shadcn/ui/**/*.ts' -c 'node ./scripts/generate-registry.mjs' --initial --silent",
        "sitemap:manifest": "node ./scripts/generate-sitemap-manifest.mjs",
        "sitemap:watch": "chokidar 'src/routes/**/*.svelte' 'src/routes/**/*.svx' 'src/routes/**/*.md' --ignore 'src/routes/examples/+page.ts' -c 'node ./scripts/generate-sitemap-manifest.mjs' --initial --silent",
        "social:watch": "chokidar 'scripts/generate-social-cards.ts' 'src/routes/**/+page.svelte' 'src/routes/**/+page.svx' -c 'tsx ./scripts/generate-social-cards.ts' --initial --silent",
        "test": "npm run test:unit -- --run",
        "test:unit": "vitest"
    },
    "dependencies": {
        "@humanspeak/docs-kit": "github:humanspeak/docs-kit#2026.3.13",
        "@humanspeak/svelte-motion": "workspace:*",
        "@inlang/paraglide-js": "^2.13.2",
        "@lucide/svelte": "^0.577.0",
        "@sentry/sveltekit": "^10.42.0",
        "bits-ui": "^2.16.3",
        "flubber": "^0.4.2",
        "github-slugger": "^2.0.0",
        "runed": "^0.37.1"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.53.4",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.1",
        "@types/flubber": "^0.4.0",
        "@vitest/browser": "^4.0.18",
        "chokidar-cli": "^3.0.0",
        "clsx": "^2.1.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-svelte": "3.15.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "^17.4.0",
        "mdsvex": "^0.12.6",
        "mode-watcher": "^1.1.0",
        "playwright": "^1.58.2",
        "prettier": "^3.8.1",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "shiki": "^4.0.1",
        "svelte": "^5.53.7",
        "svelte-check": "^4.4.5",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "vite-plugin-devtools-json": "^1.0.0",
        "vitest": "^4.0.18",
        "vitest-browser-svelte": "^2.0.2",
        "wrangler": "^4.71.0"
    },
    "volta": {
        "node": "22.16.0"
    },
    "pnpm": {}
}
